{
  "name": "smartcow",
  "version": "1.0.0",
  "description": "SmartCow — plataforma ganadera sobre PostgreSQL + Drizzle ORM",
  "bin": {
    "smartcow": "bin/smartcow"
  },
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "etl:precios-feria": "tsx src/etl/import-precios-feria.ts",
    "mobile": "kill $(lsof -ti:8081) 2>/dev/null; cd apps/mobile && npx expo start --ios",
    "mobile:dev": "kill $(lsof -ti:3003) 2>/dev/null; kill $(lsof -ti:8081) 2>/dev/null; npx concurrently --names \"next,metro\" --prefix-colors \"green,blue\" \"npm run dev\" \"cd apps/mobile && npx expo start --ios\""
  },
  "keywords": [],
  "author": "Autonomos Lab",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@auth/drizzle-adapter": "^1.11.2",
    "@google/genai": "^1.50.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^2.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jose": "^5.10.0",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-auth": "^5.0.0-beta.28",
    "openai": "^6.34.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "exceljs": "^4.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
