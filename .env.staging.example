# .env.staging.example — plantilla para el .env staging en el VPS.
# Copiar a .env.staging en el host del VPS y rellenar los <...>.

# ── Database staging (misma instancia pg, db distinta) ──
DATABASE_URL_STAGING=postgresql://smartcow_stg:<PASSWORD_STAGING>@db:5432/smartcow_staging

# ── Auth ──
NEXTAUTH_SECRET_STAGING=<generar con: openssl rand -base64 32>
NEXTAUTH_URL_STAGING=https://staging.smartcow.cl

# ── LLM + APIs (compartidas con prod) ──
GOOGLE_API_KEY=<mismo que prod>
OPENROUTER_API_KEY=<mismo que prod>

# ── AgroApp (compartidas con prod) ──
AGROAPP_USER=<mismo que prod>
AGROAPP_PASSWORD=<mismo que prod>
