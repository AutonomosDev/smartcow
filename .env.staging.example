# .env.staging.example — plantilla para staging en el VPS (AUT-286)
# Agregar estas líneas al .env principal (/var/www/smartcow/.env).
# docker-compose.staging.yml lee del mismo .env que prod, solo necesita
# vars con sufijo _STAGING + POSTGRES_PASSWORD_STAGING.

# ── Staging DB (contenedor db-staging, puerto host 5433) ──
POSTGRES_PASSWORD_STAGING=<generar con: openssl rand -base64 24>

# ── Auth staging ──
NEXTAUTH_SECRET_STAGING=<generar con: openssl rand -base64 32>
NEXTAUTH_URL_STAGING=https://staging.smartcow.cl

# ── LLM + APIs (compartidas con prod, ya están en .env) ──
# GOOGLE_API_KEY, ANTHROPIC_API_KEY, OPENROUTER_API_KEY, TAVILY_API_KEY
# LANGFUSE_SECRET_KEY, LANGFUSE_PUBLIC_KEY, LANGFUSE_HOST

# ── AgroApp (compartidas con prod) ──
# AGROAPP_USER, AGROAPP_PASSWORD
