# SmartCow — Variables de entorno
# Copiar como .env.local y completar con valores reales.
# NUNCA commitear .env.local ni .env con valores reales.
# Todos los secrets se gestionan en GCP Secret Manager proyecto smartcow-492119 (AUT-123).
#
# Estado secrets en GCP Secret Manager (2026-04-09):
#   agroapp-user            ✓  poblado  (jferrada)
#   gcp-project-id          ✓  poblado  (smartcow-492119)
#   anthropic-api-key       ✗  pendiente — console.anthropic.com → API Keys
#   database-url            ✗  pendiente — Cloud SQL smartcow-db (34.176.238.2)
#   agroapp-password        ✗  pendiente — credencial JP Ferrada
#   sentry-dsn-web          ✗  pendiente — sentry.io → smartcow-web → DSN
#   firebase-client-email   ✗  pendiente — Firebase Console → Service Account
#   firebase-private-key    ✗  pendiente — Firebase Console → Service Account
#
# ELIMINADOS (migración a Firebase Auth):
#   nextauth-secret — reemplazado por Firebase session cookies

# ─────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────
# Pendiente: crear instancia Cloud SQL en smartcow-492119.
# Formato: postgresql://USER:PASSWORD@HOST:5432/smartcow
# Una vez creada, correr:
#   echo -n "postgresql://..." | gcloud secrets versions add database-url --project=smartcow-492119 --data-file=-
DATABASE_URL=postgresql://user:password@host:5432/smartcow

# ─────────────────────────────────────────────
# Autenticación
# ─────────────────────────────────────────────
# Firebase Auth (reemplaza NextAuth v5)
# ─────────────────────────────────────────────
# 1. Firebase Console → Proyecto smartcow-492119 → Project Settings → Service accounts
#    → Generate new private key → descargar JSON
# 2. Extraer clientEmail y privateKey del JSON
# 3. Poblar en GCP Secret Manager:
#    echo -n "firebase-adminsdk-...@smartcow-492119.iam.gserviceaccount.com" | \
#      gcloud secrets versions add firebase-client-email --project=smartcow-492119 --data-file=-
#    echo -n "-----BEGIN PRIVATE KEY-----\n..." | \
#      gcloud secrets versions add firebase-private-key --project=smartcow-492119 --data-file=-
#
# Client SDK (NEXT_PUBLIC — exponer al browser):
# Firebase Console → Project Settings → General → Web apps → Add app → obtener firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=smartcow-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=smartcow-prod
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
#
# Server SDK (secretos, NO exponer):
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Claude / Anthropic
# ─────────────────────────────────────────────
# Pendiente: obtener clave en console.anthropic.com → API Keys
# Una vez obtenida, correr:
#   echo -n "sk-ant-..." | gcloud secrets versions add anthropic-api-key --project=smartcow-492119 --data-file=-
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# AgroApp (credenciales cliente JP Ferrada)
# ─────────────────────────────────────────────
# agroapp-user ya está poblado en GCP (jferrada).
# Pendiente: agroapp-password — credencial real de JP Ferrada.
#   echo -n "PASSWORD" | gcloud secrets versions add agroapp-password --project=smartcow-492119 --data-file=-
AGROAPP_USER=jferrada
AGROAPP_PASSWORD=

# ─────────────────────────────────────────────
# GCP
# ─────────────────────────────────────────────
# gcp-project-id ya está poblado en GCP (smartcow-492119).
GCP_PROJECT_ID=smartcow-492119

# ─────────────────────────────────────────────
# Observabilidad — Sentry (AUT-108)
# ─────────────────────────────────────────────
# Org Sentry: autonomosdev
# Proyectos: smartcow-web (Next.js) · smartcow-mobile (React Native)
#
# Paso 1 — Crear proyectos en sentry.io:
#   sentry.io → Settings → Projects → New Project → Next.js     → nombre: smartcow-web
#   sentry.io → Settings → Projects → New Project → React Native → nombre: smartcow-mobile
#
# Paso 2 — Obtener DSN de cada proyecto:
#   sentry.io → Settings → Projects → smartcow-web → Client Keys → DSN
#   sentry.io → Settings → Projects → smartcow-mobile → Client Keys → DSN
#
# Paso 3 — Poblar secrets GCP (secrets ya creados con PLACEHOLDER):
#   echo -n "https://KEY@o0.ingest.sentry.io/PROJECT_ID" | gcloud secrets versions add sentry-dsn-web --project=smartcow-492119 --data-file=-
#   echo -n "https://KEY@o0.ingest.sentry.io/PROJECT_ID" | gcloud secrets versions add sentry-dsn-mobile --project=smartcow-492119 --data-file=-
#
# Paso 4 — Crear SENTRY_AUTH_TOKEN para release tracking:
#   sentry.io → Settings → Auth Tokens → New Token → scopes: project:releases, org:read
#   Agregar como GitHub Secret: SENTRY_AUTH_TOKEN en repo AutonomosDev/smartcow
#
# Paso 5 — Alertas (configurar en sentry.io → Alerts → Create Alert):
#   Tipo: Error Rate  |  Threshold: > 5%  |  Ventana: 5 min
#   Proyectos: smartcow-web · smartcow-mobile
#
# Paso 6 — Source maps (Next.js):
#   En next.config.js agregar: withSentryConfig(config, { org: "autonomosdev", project: "smartcow-web" })
#   El Sentry webpack plugin sube source maps automáticamente en build de prod.
#
# CI/CD: SENTRY_DSN se inyecta via Cloud Run secret mount (ci-dev.yml y ci-prod.yml).
#        SENTRY_RELEASE se pasa como env var con el git SHA del deploy.
#        Release tracking via sentry-cli en step post-deploy (requiere SENTRY_AUTH_TOKEN como GitHub Secret).
SENTRY_DSN=https://...@o0.ingest.sentry.io/...
SENTRY_RELEASE=
