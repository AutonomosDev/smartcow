# SmartCow — Variables de entorno
# Copiar como .env.local y completar con valores reales.
# NUNCA commitear .env.local ni .env con valores reales.
# Todos los secrets se gestionan en GCP Secret Manager proyecto smartcow-492119 (AUT-123).
#
# Estado secrets en GCP Secret Manager (2026-04-02):
#   agroapp-user       ✓  poblado  (jferrada)
#   nextauth-secret    ✓  poblado  (generado con openssl rand -base64 32)
#   gcp-project-id     ✓  poblado  (smartcow-492119)
#   anthropic-api-key  ✗  pendiente — obtener de console.anthropic.com → API Keys
#   database-url       ✗  pendiente — obtener de Cloud SQL una vez creada la instancia
#   agroapp-password   ✗  pendiente — credencial cliente JP Ferrada
#   sentry-dsn-web     ✗  pendiente — obtener de sentry.io → Settings → Projects → smartcow-web → DSN
#   sentry-dsn-mobile  ✗  pendiente — obtener de sentry.io → Settings → Projects → smartcow-mobile → DSN

# ─────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────
# Pendiente: crear instancia Cloud SQL en smartcow-492119.
# Formato: postgresql://USER:PASSWORD@HOST:5432/smartcow
# Una vez creada, correr:
#   echo -n "postgresql://..." | gcloud secrets versions add database-url --project=smartcow-492119 --data-file=-
DATABASE_URL=postgresql://user:password@host:5432/smartcow

# ─────────────────────────────────────────────
# Autenticación
# ─────────────────────────────────────────────
# nextauth-secret ya está poblado en GCP Secret Manager.
# Para desarrollo local, generar uno nuevo:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Claude / Anthropic
# ─────────────────────────────────────────────
# Pendiente: obtener clave en console.anthropic.com → API Keys
# Una vez obtenida, correr:
#   echo -n "sk-ant-..." | gcloud secrets versions add anthropic-api-key --project=smartcow-492119 --data-file=-
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# AgroApp (credenciales cliente JP Ferrada)
# ─────────────────────────────────────────────
# agroapp-user ya está poblado en GCP (jferrada).
# Pendiente: agroapp-password — credencial real de JP Ferrada.
#   echo -n "PASSWORD" | gcloud secrets versions add agroapp-password --project=smartcow-492119 --data-file=-
AGROAPP_USER=jferrada
AGROAPP_PASSWORD=

# ─────────────────────────────────────────────
# GCP
# ─────────────────────────────────────────────
# gcp-project-id ya está poblado en GCP (smartcow-492119).
GCP_PROJECT_ID=smartcow-492119

# ─────────────────────────────────────────────
# Observabilidad — Sentry
# ─────────────────────────────────────────────
# Pendiente: crear proyectos en sentry.io bajo org AutonomosDev.
#   Web:    sentry.io → Settings → Projects → New Project → Next.js → copiar DSN
#   Mobile: sentry.io → Settings → Projects → New Project → React Native → copiar DSN
# Una vez obtenidos, correr:
#   echo -n "https://KEY@sentry.io/PROJECT_ID" | gcloud secrets versions add sentry-dsn-web --project=smartcow-492119 --data-file=-
#   echo -n "https://KEY@sentry.io/PROJECT_ID" | gcloud secrets versions add sentry-dsn-mobile --project=smartcow-492119 --data-file=-
SENTRY_DSN_WEB=https://...@sentry.io/...
SENTRY_DSN_MOBILE=https://...@sentry.io/...
