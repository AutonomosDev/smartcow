# SmartCow — Variables de entorno
# Copiar como .env.local y completar con valores reales.
# NUNCA commitear .env.local ni .env con valores reales.
# AUT-215: migrado de GCP + Firebase → Hostinger VPS + Next-Auth

# ─────────────────────────────────────────────
# Base de datos — Hostinger PostgreSQL
# ─────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@localhost:5432/smartcow
# En Hostinger VPS PostgreSQL corre en localhost
DATABASE_URL=postgresql://smartcow:password@localhost:5432/smartcow

# ─────────────────────────────────────────────
# Next-Auth (reemplaza Firebase Auth)
# ─────────────────────────────────────────────
# Generar secret: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://smartcow.cl
# Para desarrollo local:
# NEXTAUTH_URL=http://localhost:3003

# ─────────────────────────────────────────────
# Google OAuth (mismo proyecto Google Cloud)
# ─────────────────────────────────────────────
# console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: https://smartcow.cl/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Anthropic — LLM principal del chat ganadero (AUT-261)
# Modelos aprobados: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-7
# Ver .claude/references/config/llm-routing-and-budget.yaml
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Google AI SDK — tool declarations (FunctionDeclaration en src/lib/claude.ts)
# ─────────────────────────────────────────────
GOOGLE_API_KEY=

# ─────────────────────────────────────────────
# Tavily — Web search (toggle 🌐 en chat)
# Plan free: 100 búsquedas/mes. Dashboard: app.tavily.com
# ─────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─────────────────────────────────────────────
# Linear API — feedback conversacional (AUT-277)
# Genera en: https://linear.app/settings/api — Personal API Keys
# ─────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...

# ─────────────────────────────────────────────
# OpenRouter (legacy — deprecated tras AUT-261, pendiente cleanup)
# ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ─────────────────────────────────────────────
# Mapbox
# ─────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─────────────────────────────────────────────
# AgroApp (credenciales cliente JP Ferrada)
# ─────────────────────────────────────────────
AGROAPP_USER=jferrada
AGROAPP_PASSWORD=

# ─────────────────────────────────────────────
# Redis (cache APIs externas — AUT-212)
# ─────────────────────────────────────────────
# En Hostinger VPS Redis corre en localhost
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Langfuse — Observabilidad LLM self-hosted (AUT-278 — v3 stack)
# Ver docs/deploy/langfuse-setup.md para instrucciones de deploy.
# LANGFUSE_HOST: URL interna del contenedor (docker network).
#   - En prod VPS: http://langfuse-web:3000 (docker compose internal — v3)
#   - En dev sin Langfuse: dejar vacío → langfuse = null (no crashea)
# LANGFUSE_SECRET_KEY / LANGFUSE_PUBLIC_KEY: obtener desde
#   https://langfuse.smartcow.cl → Settings → API Keys
# ─────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://langfuse-web:3000

# Langfuse v3 — service env vars (solo VPS docker-compose — NO en app .env)
# Generar secrets con: openssl rand -base64 32
# LANGFUSE_DATABASE_URL=postgresql://smartcow:password@db:5432/langfuse
# LANGFUSE_NEXTAUTH_URL=https://langfuse.smartcow.cl
# LANGFUSE_NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# LANGFUSE_SALT=change-me-generate-with-openssl-rand-base64-32
# LANGFUSE_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Langfuse v3 — ClickHouse
# CLICKHOUSE_URL=http://clickhouse:8123
# CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000
# CLICKHOUSE_USER=clickhouse
# CLICKHOUSE_PASSWORD=change-me-clickhouse-password
# CLICKHOUSE_CLUSTER_ENABLED=false

# Langfuse v3 — MinIO (S3-compatible, event sourcing)
# LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
# LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
# LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
# LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=change-me-minio-secret
# LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
# LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
# LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse
# LANGFUSE_S3_MEDIA_UPLOAD_REGION=us-east-1
# LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
# LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=change-me-minio-secret
# LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://minio:9000
# LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true

# Langfuse v3 — MinIO root credentials
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=change-me-minio-password

# Langfuse v3 — Redis dedicado (separado del redis de la app)
# LANGFUSE_REDIS_AUTH=change-me-redis-password

# ─────────────────────────────────────────────
# ELIMINADAS (AUT-215 — migración Firebase → Next-Auth)
# ─────────────────────────────────────────────
# NEXT_PUBLIC_FIREBASE_API_KEY
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
# NEXT_PUBLIC_FIREBASE_PROJECT_ID
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
# NEXT_PUBLIC_FIREBASE_APP_ID
# FIREBASE_CLIENT_EMAIL
# FIREBASE_PRIVATE_KEY
# GCP_PROJECT_ID
# K_SERVICE (Cloud Run)
